# ─────────────────────────────────────────────
# NexShop – Environment Configuration Example
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Database
# Use PostgreSQL for production:
DATABASE_URL=postgresql://postgres:fsha@localhost:5432/ecommerce_db
# Or leave blank to use SQLite (development only):
# DATABASE_URL=sqlite:///./ecommerce.db

# JWT Security (change to a long random string in production!)
SECRET_KEY=replace_with_a_very_long_random_secret_key_here

# Token lifespan in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
